
# Documenter build output (deployed via gh-pages, not tracked)
docs/build/

# Resolved manifests are Julia-version specific; let CI resolve per-version.
# (A 1.12-resolved manifest force-installs PrecompileTools 1.3.x, which is
#  Julia-1.12-only, and breaks the 1.10/1.11 jobs at precompile.)
/Manifest.toml
/docs/Manifest.toml

# Coverage artifacts (generated by Pkg.test(coverage=true) / processcoverage)
*.cov
lcov.info
